{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "Display name of the user" },
        "email": { "type": "string", "description": "Email address" },
        "avatar": { "type": "string", "description": "Avatar SVG URL" }
      },
      "required": ["name", "email"]
    },
    "Account": {
      "title": "Account",
      "description": "Financial account (e.g., Bkash, Cash)",
      "type": "object",
      "properties": {
        "userId": { "type": "string", "description": "Firebase Auth UID" },
        "name": { "type": "string" },
        "initialBalance": { "type": "number" },
        "currentBalance": { "type": "number" },
        "type": { "type": "string" }
      },
      "required": ["userId", "name", "initialBalance", "currentBalance", "type"]
    },
    "Category": {
      "title": "Category",
      "description": "Transaction category",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "name": { "type": "string" },
        "type": { "type": "string", "enum": ["income", "expense"] },
        "icon": { "type": "string" },
        "color": { "type": "string" }
      },
      "required": ["userId", "name", "type"]
    },
    "Transaction": {
      "title": "Transaction",
      "description": "Cash transaction",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "amount": { "type": "number" },
        "type": { "type": "string", "enum": ["income", "expense"] },
        "categoryId": { "type": "string" },
        "accountId": { "type": "string" },
        "date": { "type": "string", "format": "date-time" },
        "note": { "type": "string" }
      },
      "required": ["userId", "amount", "type", "categoryId", "accountId", "date"]
    },
    "RecurringTransaction": {
      "title": "RecurringTransaction",
      "description": "Recurring transaction scheduler",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "amount": { "type": "number" },
        "type": { "type": "string", "enum": ["income", "expense"] },
        "categoryId": { "type": "string" },
        "accountId": { "type": "string" },
        "frequency": { "type": "string", "enum": ["daily", "weekly", "monthly", "yearly"] },
        "startDate": { "type": "string", "format": "date-time" },
        "endDate": { "type": "string", "format": "date-time" },
        "lastGeneratedDate": { "type": "string", "format": "date-time" },
        "dueDate": { "type": "number" },
        "note": { "type": "string" }
      },
      "required": ["userId", "amount", "type", "categoryId", "accountId", "frequency", "startDate"]
    },
    "Debt": {
      "title": "Debt",
      "description": "Payable or receivable debt records",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "person": { "type": "string" },
        "amount": { "type": "number" },
        "type": { "type": "string", "enum": ["payable", "receivable"] },
        "status": { "type": "string", "enum": ["paid", "unpaid"] },
        "date": { "type": "string", "format": "date-time" },
        "dueDate": { "type": "string", "format": "date-time" },
        "note": { "type": "string" },
        "phoneNumber": { "type": "string" },
        "whatsappNumber": { "type": "string" },
        "remainingAmount": { "type": "number" },
        "payments": { "type": "array" }
      },
      "required": ["userId", "person", "amount", "type", "status", "date"]
    },
    "Note": {
      "title": "Note",
      "description": "Personal pinned/unpinned notes",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "title": { "type": "string" },
        "content": { "type": "string" },
        "color": { "type": "string" },
        "date": { "type": "string", "format": "date-time" },
        "pinned": { "type": "boolean" }
      },
      "required": ["userId", "title", "content", "date", "pinned"]
    },
    "AppNotification": {
      "title": "AppNotification",
      "description": "User notifications",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "title": { "type": "string" },
        "message": { "type": "string" },
        "type": { "type": "string", "enum": ["info", "warning", "success", "report"] },
        "date": { "type": "string", "format": "date-time" },
        "read": { "type": "boolean" },
        "link": { "type": "string" }
      },
      "required": ["userId", "title", "message", "type", "date", "read"]
    },
    "BazarList": {
      "title": "BazarList",
      "description": "User shopping lists and items",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "title": { "type": "string" },
        "items": { "type": "array" },
        "date": { "type": "string", "format": "date-time" },
        "totalAmount": { "type": "number" }
      },
      "required": ["userId", "title", "items", "date", "totalAmount"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "Stores user profiles keyed by their Firebase Auth UID."
    },
    "/accounts/{accountId}": {
      "schema": "Account",
      "description": "A collection of users' financial accounts"
    },
    "/categories/{categoryId}": {
      "schema": "Category",
      "description": "User financial transaction categories"
    },
    "/transactions/{transactionId}": {
      "schema": "Transaction",
      "description": "Users' financial transactions"
    },
    "/recurringTransactions/{recurringId}": {
      "schema": "RecurringTransaction",
      "description": "User schedule for recurring entries"
    },
    "/debts/{debtId}": {
      "schema": "Debt",
      "description": "Debt tracking entries (payable/receivable)"
    },
    "/notes/{noteId}": {
      "schema": "Note",
      "description": "User personal diary notes"
    },
    "/notifications/{notificationId}": {
      "schema": "AppNotification",
      "description": "In-app notifications for users"
    },
    "/bazarLists/{bazarListId}": {
      "schema": "BazarList",
      "description": "User shopping lists and items"
    }
  }
}
